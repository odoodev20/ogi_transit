<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_ogi_transit" model="ir.module.category">
            <field name="name">OGI Transit</field>
            <field name="sequence">10</field>
        </record>

        <!-- 1. ADMIN -->
        <record id="group_ogi_admin" model="res.groups">
            <field name="name">Admin (System Config)</field>
            <field name="category_id" ref="module_category_ogi_transit"/>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user'), ref('base.group_allow_export')])]"/>
        </record>

        <!-- 2. CEO -->
        <record id="group_ogi_pdg" model="res.groups">
            <field name="name">CEO</field>
            <field name="category_id" ref="module_category_ogi_transit"/>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user'), ref('base.group_allow_export')])]"/>
        </record>

        <!-- 3. MANAGER -->
        <record id="group_ogi_gerant" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_ogi_transit"/>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user'), ref('base.group_allow_export')])]"/>
        </record>

        <!-- 4. FINANCE / CASHIER -->
        <record id="group_ogi_finance" model="res.groups">
            <field name="name">Finance / Cashier</field>
            <field name="category_id" ref="module_category_ogi_transit"/>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user'), ref('base.group_allow_export')])]"/>
        </record>

        <!-- 5. LOGISTICS MANAGER -->
        <record id="group_ogi_logistics" model="res.groups">
            <field name="name">Logistics Manager</field>
            <field name="category_id" ref="module_category_ogi_transit"/>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user'), ref('base.group_allow_export')])]"/>
        </record>

        <!-- 6. WAREHOUSE OPERATOR (Kept restricted) -->
        <record id="group_ogi_operator" model="res.groups">
            <field name="name">Warehouse Operator</field>
            <field name="category_id" ref="module_category_ogi_transit"/>
            <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        </record>
    </data>
</odoo>